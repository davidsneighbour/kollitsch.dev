---
import { getCollection } from "astro:content";

import ArticleCard from "@components/content/article/Preview.astro";
import Layout from "@layouts/DefaultPage.astro";
import setup from "@data/setup.json" with { type: "json" };

const allPosts = await getCollection("blog");
const draftPosts = allPosts
  .filter((post) => post.data.draft === true)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const post = {
  data: {
    description: "All posts currently in draft status.",
    title: `Draft Posts | ${setup.title}`,
  },
};
---

<Layout post={post}>
  <section class="mb-4 border-b border-gray-200 text-center dark:border-gray-700">
    <h1>Draft Posts</h1>
    <p class="text-gray-500 dark:text-gray-400">All posts currently in draft status.</p>
  </section>

  {
    !import.meta.env.DEV && (
      <div class="mb-6 rounded-lg border border-orange-300 bg-orange-50 px-4 py-3 text-sm text-orange-800 dark:border-orange-700 dark:bg-orange-950 dark:text-orange-200">
        This page is a development tool. In a standard production build all
        <code>draft: true</code> posts are excluded from listings and routes.
        If you see posts here in production, remove the <code>draft</code> flag
        before deploying.
      </div>
    )
  }

  {
    draftPosts.length === 0 ? (
      <p class="py-12 text-center text-gray-500 dark:text-gray-400">
        No draft posts found.
        {import.meta.env.DEV
          ? " Add draft: true to a post's frontmatter to see it here."
          : " All posts have been published."}
      </p>
    ) : (
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-3">
        {draftPosts.map((draftPost) => (
          <ArticleCard post={draftPost} />
        ))}
      </div>
    )
  }
</Layout>
