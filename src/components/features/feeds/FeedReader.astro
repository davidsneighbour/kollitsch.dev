---
import feedThisAndThat from "@assets/images/interface/feed-this-and-that.jpg";
import feedWebTech from "@assets/images/interface/feed-web-tech-development.jpg";
import CardLink from "@components/ui/CardLink.astro";
import type { ImageMetadata } from "astro";

export interface Props {
  /**
   * Label text for the vertical label on the left side.
   * @default "Follower Feeds"
   */
  label?: string;

  /**
   * Description text for the feed reader.
   * @default "Read an eclectic selection of Patrick's reading"
   */
  description?: string;

  /**
   * Link URL for the Web, Tech & Development feed.
   * @default "https://kollitsch.dev/dnb-webdev.rss.xml"
   */
  linkWebTech?: string;

  /**
   * Link URL for the This & That feed.
   * @default "https://kollitsch.dev/dnb-entertainment.rss.xml"
   */
  linkThisAndThat?: string;
}

interface FeedCard {
  title: string;
  href: string;
  image: ImageMetadata;
  alt: string;
}

const {
  label = "Follower Feeds",
  description = "Read an eclectic selection of Patrick's reading",
  linkWebTech = "https://kollitsch.dev/dnb-webdev.rss.xml",
  linkThisAndThat = "https://kollitsch.dev/dnb-entertainment.rss.xml",
}: Props = Astro.props;

const descriptionId = "follower-feeds-description";

const feeds: FeedCard[] = [
  {
    alt: "Web, Tech and Development feed",
    href: linkWebTech,
    image: feedWebTech,
    title: "Web, Tech & Development",
  },
  {
    alt: "This & That feed",
    href: linkThisAndThat,
    image: feedThisAndThat,
    title: "This & That",
  },
];
---

<div class="typography-ui flex flex-col items-stretch gap-4 md:flex-row md:shrink-0 mx-2">
  <div class="flex md:items-stretch">
    <h3
      class="text-boxlabel-inherit text-center text-sm uppercase text-gray-800 md:text-boxlabel-sideways"
      aria-describedby={descriptionId}
    >
      {label}
    </h3>
    <p id={descriptionId} class="sr-only">
      {description}
    </p>
  </div>
  {feeds.map((feed) => <CardLink href={feed.href} title={feed.title} image={feed.image} alt={feed.alt} />)}
</div>
