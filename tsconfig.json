{
  "extends": "astro/tsconfigs/strictest",
  "compilerOptions": {
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@assets/*": [
        "./src/assets/*"
      ],
      "@components/*": [
        "./src/components/*"
      ],
      "@config/*": [
        "./src/config/*"
      ],
      "@content/*": [
        "./src/content/*"
      ],
      "@contentconfig": [
        "./src/content.config.ts"
      ],
      "@data/*": [
        "./src/data/*"
      ],
      "@layouts/*": [
        "./src/layouts/*"
      ],
      "@packages/*": [
        "./src/packages/*"
      ],
      "@pages/*": [
        "./src/pages/*"
      ],
      "@scripts/*": [
        "./src/scripts/*"
      ],
      "@styles/*": [
        "./src/styles/*"
      ],
      "@test/*": [
        "./src/test/*"
      ],
      "@utils/*": [
        "./src/utils/*"
      ]
    },
    "plugins": [
      {
        "name": "@astrojs/ts-plugin"
      }
    ],
    "types": [
      "astro/client"
    ],
    "verbatimModuleSyntax": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  },
  "include": [
    ".astro/types.d.ts",
    "src"
  ],
  "exclude": [
    "dist",
    "scratch",
    "src/scripts"
  ]
}