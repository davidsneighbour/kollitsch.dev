  "scripts": {
    "clean:full": "wireit",
    "packages:generate": "wireit",
    "packages:update": "wireit",
    "postinstall:sharedconfig": "npm run prepare:sharedconfig",
    "prepare:sharedconfig": "npx tsx src/config/shared-config-create.ts",
    "release": "wireit",
    "release:tests": "wireit",
    "screenshot": "wireit",
    "firewall:allow": "bash -c 'sudo ufw allow from 192.168.1.0/24 to any port 1313 proto tcp comment \"Allow dev server on LAN\" || true'",
    "firewall:cleanup": "bash -c 'sudo ufw delete allow from 192.168.1.0/24 to any port 1313 proto tcp || true'",
    "build:vscode:recommendations": "node --disable-warning=ExperimentalWarning src/scripts/vscode/vscode-extensions.ts --fix",
    "ci:check:vscode": "npm run vscode:check",
    "postinstall:vscode": "npm run vscode:sync",
    "vscode:check": "node src/scripts/vscode/merge-vscode-config.ts --check",
    "vscode:sync": "node src/scripts/vscode/merge-vscode-config.ts --apply",
    "biome:check": "biome check",
    "biome:format": "biome format",
    "biome:lint": "biome check --fix",
    "biome:postinstall": "biome migrate --write",
    "biome:watch": "biome check --watch",
    "lint:spell": "cspell 'src/{*,.*}/**/*.{md,mdx}'",
    "audit:html": "wireit",
    "lighthouse": "bin/audit/lighthouse",
    "lint:hook:commit": "lint-staged",
    "lint:html": "html-validate --config=src/config/htmlvalidate.json dist/**/*.html",
    "lint:html:config": "html-validate --print-config=src/config/htmlvalidate.json",
    "lint:templates": "wireit",
    "lint:lychee": "wireit",
    "lint:markdown": "markdownlint-cli2 --config src/config/.markdownlint.jsonc src/content/blog/**/*.{md,mdx}",
    "lint:markdown:fix": "markdownlint-cli2 --config src/config/.markdownlint.jsonc --fix src/content/blog/**/*.{md,mdx}",
    "lint:filenames": "ls-lint",
    "lint:secretlint": "secretlint --secretlintrc src/config/secretlint/.secretlintrc.json --secretlintignore src/config/secretlint/.secretlintignore",
    "lint:design": "npx @google/design.md lint DESIGN.md",
    "lint:design:diff": "npx @google/design.md diff DESIGN.md",
    "lint:styles": "wireit",
    "lint:styles:fix": "wireit",
    "lint:vale": "vale --config src/config/.vale.ini --no-exit --output='dnb.tmpl' ./src/content/",
    "update:pre:vale": "wireit",
    "astro": "astro",
    "build": "astro check && astro build && rm -rf dist/test/",
    "build:profile": "DEBUG=astro:build,OpenGraphImage npx astro build --verbose | tee .cache/build.log",
    "check": "astro check",
    "clean:astro": "wireit",
    "clean:og": "wireit",
    "create:blog": "node src/scripts/create-blog-post.ts",
    "dev": "astro dev",
    "dev:verbose": "DEBUG_FRONTMATTER=true astro dev --verbose",
    "preview": "astro preview",
    "upgrade": "npx @astrojs/upgrade",
    "bbuild:blogroll": "node src/scripts/blogroll-screenshots.ts --input src/content/blogroll.json --out-dir src/assets/images/blogroll/",
    "build:favicons": "node src/assets/favicon/regenerate.ts",
    "icons:sync": "node src/scripts/create-icon-types.ts",
    "postinstall:icons": "npm run icons:sync",
    "build:image-index": "node src/scripts/build-image-index.ts --images src/assets/images --frontmatter-db .frontmatter/database/mediaDb.json --out src/content/_generated/image-index.json --lqip-width 24 --concurrency 4",
    "prebuild": "npm run build:image-index",
    "clean:netlify": "wireit",
    "deploy": "wireit",
    "postprepare": "wireit",
    "lighthouse:audit": "wireit",
    "test:sitemap": "tsx src/scripts/verify-sitemap.ts --sitemap-index https://kollitsch.dev/sitemap-index.xml --delay-ms 1000",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:live": "npx playwright test --config ./playwright.live.config.ts",
    "test:postinstall": "npx playwright install",
    "test:ui": "vitest --ui",
    "hooks:update": "simple-git-hooks",
    "postinstall": "run-p postinstall:*",
    "postinstall:favicons": "node ./src/assets/favicon/regenerate.ts",
    "update": "wireit"
  },
  "wireit": {
    "clean:full": {
      "command": "clean:full:last",
      "dependencies": [
        "clean:full:items"
      ]
    },
    "clean:full:items": {
      "command": "run-p clean:*"
    },
    "clean:full:last": {
      "command": "rm -rf node_modules package-lock.json .wireit"
    },
    "compile:fixpack": {
      "command": "fixpack --config ci/.fixpackrc.json || true && fixpack --config ci/.fixpackrc.json || true"
    },
    "compile:package": {
      "dependencies": [
        "compile:package:install",
        "compile:package:run"
      ],
      "files": [
        "./src/packages/**/*.jsonc"
      ]
    },
    "compile:package:install": {
      "command": "npm install",
      "dependencies": [
        "compile:fixpack"
      ]
    },
    "compile:package:run": {
      "command": "node ./src/packages/generate-package.ts"
    },
    "packages:generate": {
      "command": "node ./src/packages/generate-package.ts",
      "dependencies": [
        "compile:package"
      ],
      "files": [
        "./src/packages/**/*.jsonc"
      ]
    },
    "packages:update": {
      "command": "node ./src/packages/update-package.ts",
      "dependencies": [
        "compile:fixpack"
      ]
    },
    "release": {
      "command": "DEBUG=* release-it --ci --config .release-it.ts",
      "dependencies": [
        "release:tests"
      ]
    },
    "release:tests": {
      "command": "npx astro check",
      "dependencies": [
        "test",
        "test:e2e"
      ]
    },
    "screenshot": {
      "command": "node src/scripts/screenshot.ts --url=https://kollitsch.dev/ --width=1280 --format=png --scheme=dark --output=.github/screenshot.png --scroll-step=500 --scroll-delay=250 --settle-ms=5000 --timeout=120000"
    },
    "audit:html": {
      "command": "npm run build && html-validate dist/**/*.html --config=src/config/htmlvalidate.json"
    },
    "lint:templates": {
      "command": "bin/hugo/lint-templates"
    },
    "lint:lychee": {
      "command": "lychee --no-progress --config ./src/config/lychee.toml --require-https --format detailed --mode color -vv src/content/"
    },
    "lint:styles": {
      "command": "stylelint -f verbose --config src/config/stylelint/index.js --color --report-descriptionless-disables --report-invalid-scope-disables --report-needless-disables --ignore-path src/config/stylelint/.stylelintignore src/styles/**/*.css"
    },
    "lint:styles:fix": {
      "command": "stylelint --fix --config src/config/stylelint/index.js --color --report-descriptionless-disables --report-invalid-scope-disables --report-needless-disables --ignore-path src/config/stylelint/.stylelintignore src/styles/**/*.css"
    },
    "update:pre:vale": {
      "command": "vale --config src/config/.vale.ini --no-exit sync"
    },
    "clean:astro": {
      "command": "rm -rf .astro dist node_modules/.astro"
    },
    "clean:og": {
      "command": "rm -rf public/og_image .cache/og_image"
    },
    "clean:netlify": {
      "command": "find .netlify -type f ! -name \".gitignore\" -delete"
    },
    "deploy": {
      "command": "netlify deploy --prod --open"
    },
    "postprepare": {
      "dependencies": [
        "test:postinstall",
        "build:favicons"
      ]
    },
    "lighthouse:audit": {
      "command": "node src/scripts/lighthouse-audit.ts"
    },
    "update": {
      "dependencies": [
        "update:git-hooks"
      ]
    },
    "update:git-hooks": {
      "command": "npm test && npx simple-git-hooks",
      "dependencies": [
        "update:post"
      ]
    },
    "update:post": {
      "command": "fixpack && browserslist --update-db",
      "dependencies": [
        "update:pre:npm",
        "update:pre:submodules"
      ]
    },
    "update:pre:npm": {
      "command": "npm-check-updates -u --target minor"
    },
    "update:pre:submodules": {
      "command": "git submodule update --recursive --remote"
    }
  },
  "cspell": {
    "import": [
      "./src/config/cspell/cspell.jsonc"
    ],
    "version": "0.2"
  },
  "stylelint": {
    "configFile": "./src/config/stylelint/index.js"
  },
  "browserslist": {
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version",
      "last 1 ie version"
    ],
    "production": [
      "last 1 version",
      "Chrome >= 112",
      "Firefox >= 121",
      "iOS >= 16",
      "Safari >= 16.4",
      "Edge >= 112",
      "not ie > 0",
      "not ie_mob > 0",
      "not dead",
      "not op_mini all",
      "not op_mob > 0",
      "not opera > 0",
      "not ucandroid > 0",
      "not and_uc > 0",
      "not and_qq > 0",
      "not kaios 2.5"
    ]
  },
  "allowScripts": {
    "@sentry/cli@2.58.6": true,
    "esbuild@0.27.7": true,
    "esbuild@0.28.0": true,
    "gifsicle@5.3.0": true,
    "jpegtran-bin@7.0.0": true,
    "optipng-bin@7.0.1": true,
    "secp256k1@5.0.1": true,
    "sharp@0.34.5": true,
    "simple-git-hooks@2.13.1": true
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  }
}
