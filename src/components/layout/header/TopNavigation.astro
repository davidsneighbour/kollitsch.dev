---
// astro imports
import { fade } from "astro:transitions";

import type { Navigation } from "@utils/navigation";

// components
import IconLink from "@components/shared/links/IconLink.astro";
import ProgressBar from "@components/layout/header/Progress.astro";

// data
import setup from "@data/setup.json" with { type: "json" };
import navData from "@data/topnavigation.json" with { type: "json" };

// utilities
import { Icon } from "astro-icon/components";
import { getHomepageUrl } from "@utils/content.ts";
import { createLogger } from "@utils/logger.ts";
import { findActive, isActive } from "@utils/navigation.ts";

const typedNavData = navData as Navigation;

const log = createLogger({ slug: "TopNavigation" });

const pathname = Astro.url.pathname;
const activeItem = findActive(typedNavData, pathname);
const tagPrefixes = ["/tags/", "/tag/"];
const isTagsPath = tagPrefixes.some((prefix) => pathname.startsWith(prefix));
const isNavItemActive = (item: Navigation[number]) => (isTagsPath ? item.link === "/tags/" : isActive(item, pathname));

if (!activeItem && import.meta.env.DEV) {
  log.debug(`👉 no navigation item to activate for: ${pathname}`);
}

type ThemeMode = "dark" | "light";
type StoredThemeMode = ThemeMode | "auto";

export interface Props {
  defaultTheme?: StoredThemeMode;
  siteTitleId?: string;
}

const { defaultTheme = "dark", siteTitleId = "sitetitle" }: Props = Astro.props;
---

<header
  class="sticky top-0 right-0 left-0 isolate z-50 mb-12 bg-zinc-100 [--thickness:4px] lg:[--thickness:6px] dark:bg-zinc-900"
  aria-label="Top navigation bar with site title, navigation links, and theme selector"
>
  <nav class="mx-auto max-w-7xl" aria-label="Main navigation">
    <div class="backdrop pointer-events-none absolute inset-0 z-10 bg-gray-100 backdrop-blur-lg dark:bg-gray-900"></div>
    <div class="backdrop-edge absolute right-0 bottom-0 left-0 z-10 h-[var(--thickness)]">
      <ProgressBar classes="progress relative z-40 [--height:var(--thickness)]" />
    </div>

    <div
      class="z-20 flex flex-wrap items-center gap-4 bg-zinc-100 text-gray-950 md:flex-nowrap md:items-start dark:bg-zinc-900 dark:text-gray-50"
    >
      <div class="z-30 order-1 flex-1" id="navbar-sitetitle">
        <a
          id="navbar-brand"
          href={getHomepageUrl()}
          class="font-changa flex-rows flex items-center gap-2 p-1.5 text-2xl opacity-0 transition-opacity duration-600 ease-in-out"
        >
          <Icon name="house-fill" class="place-self-center" />
          {setup.title}
        </a>
      </div>

      <div class="z-30 order-2 md:hidden" id="hamburger-and-close">
        <Icon
          name="list"
          class="is--mobile-menu-hamburger open-icon place-self-center text-xl text-brand-500 dark:text-brand-400"
        />
        <Icon
          name="x"
          class="is--mobile-menu-hamburger close-icon hidden place-self-center text-xl text-brand-500 dark:text-brand-400"
        />
      </div>

      <div
        class="z-30 order-3 w-full justify-center self-center text-center md:order-2 md:ml-auto md:w-auto"
        id="navigation-and-theme-select"
      >
        <ul
          class="flex flex-col justify-center md:flex-row md:justify-end"
          transition:animate={fade({ duration: "0.4s" })}
        >
          {
            typedNavData.map((value) => (
              <li class={`px-3 py-4 md:px-2 md:py-2 ${isNavItemActive(value) ? "font-bold" : ""}`}>
                <IconLink icon={value.icon} href={value.link}>
                  {value.label}
                </IconLink>
              </li>
            ))
          }

          <li class="px-3 py-4 md:px-2 md:py-2">
            <theme-selector></theme-selector>
          </li>
        </ul>
      </div>
    </div>
  </nav>
</header>

<script is:inline data-astro-rerun data-default-theme={defaultTheme} data-site-title-id={siteTitleId}>
  (() => {
    /**
     * @typedef {"dark" | "light"} ThemeMode
     * @typedef {"dark" | "light" | "auto"} StoredThemeMode
     */

    /**
     * @typedef ThemeManager
     * @property {() => ThemeMode} getSystemTheme
     * @property {() => StoredThemeMode} getTheme
     * @property {() => void} resetTheme
     * @property {(theme?: StoredThemeMode) => void} setTheme
     */

    window.kdev = window.kdev || {};
    window.kdev.mobileOpen = false;

    const currentScript = document.currentScript;
    const defaultThemeAttr = currentScript?.getAttribute("data-default-theme") ?? "dark";
    const defaultTheme = defaultThemeAttr === "auto" ? "auto" : defaultThemeAttr === "light" ? "light" : "dark";

    const closeIcon = document.querySelector(".close-icon");
    const openIcon = document.querySelector(".open-icon");
    const navSection = document.querySelector("#navigation-and-theme-select");
    const placeholderId = currentScript?.getAttribute("data-site-title-id");
    const placeholder = placeholderId ? document.querySelector(`#${placeholderId}`) : null;
    const stickyBrand = document.querySelector("#navbar-brand");

    /**
     * @returns {void}
     */
    function toggleIcons() {
      closeIcon?.classList.toggle("hidden", !window.kdev.mobileOpen);
      openIcon?.classList.toggle("hidden", window.kdev.mobileOpen);
    }

    /**
     * @returns {void}
     */
    function toggleNavVisibility() {
      const isMdUp = window.matchMedia("(min-width: 768px)").matches;
      const shouldShow = isMdUp || window.kdev.mobileOpen;
      navSection?.classList.toggle("hidden", !shouldShow);
      navSection?.classList.toggle("flex", shouldShow);
    }

    /**
     * @returns {void}
     */
    function initMobileMenu() {
      window.kdev.mobileOpen = false;
      toggleIcons();
      toggleNavVisibility();

      const menuToggle = document.querySelector("#hamburger-and-close");
      if (!(menuToggle instanceof HTMLElement)) {
        return;
      }

      const clone = menuToggle.cloneNode(true);
      if (!(clone instanceof HTMLElement)) {
        return;
      }

      menuToggle.replaceWith(clone);
      clone.addEventListener("click", () => {
        window.kdev.mobileOpen = !window.kdev.mobileOpen;
        toggleIcons();
        toggleNavVisibility();
      });
    }

    /**
     * @returns {void}
     */
    function initStickyBrandObserver() {
      if (!(placeholder instanceof Element) || !(stickyBrand instanceof HTMLElement)) {
        return;
      }

      const observer = new IntersectionObserver(
        ([entry]) => {
          stickyBrand.classList.toggle("opacity-100", !entry.isIntersecting);
          stickyBrand.classList.toggle("opacity-0", entry.isIntersecting);
        },
        { threshold: 0 },
      );

      observer.observe(placeholder);

      const rect = placeholder.getBoundingClientRect();
      const isIntersecting = rect.top >= 0 && rect.bottom > 0;
      stickyBrand.classList.toggle("sticky-visible", !isIntersecting);
    }

    /**
     * @param {ThemeMode} theme
     * @returns {void}
     */
    function changeGiscusTheme(theme = "dark") {
      const iframe = document.querySelector("iframe.giscus-frame");
      if (!(iframe instanceof HTMLIFrameElement) || !iframe.contentWindow) {
        return;
      }

      iframe.contentWindow.postMessage({ giscus: { setConfig: { theme } } }, "https://giscus.app");
    }

    /**
     * @returns {ThemeManager}
     */
    function createThemeManager() {
      const storageKey = "kdev-theme";
      const store =
        typeof localStorage !== "undefined"
          ? localStorage
          : {
              getItem() {
                return null;
              },
              removeItem() {
                return;
              },
              setItem() {
                return;
              },
            };

      const mediaMatcher = window.matchMedia("(prefers-color-scheme: dark)");
      /** @type {ThemeMode} */
      let systemTheme = mediaMatcher.matches ? "dark" : "light";

      /**
       * @param {StoredThemeMode} theme
       * @returns {ThemeMode}
       */
      function resolveTheme(theme) {
        return theme === "auto" ? systemTheme : theme;
      }

      /**
       * @param {StoredThemeMode} theme
       * @returns {void}
       */
      function applyTheme(theme) {
        const resolvedTheme = resolveTheme(theme);
        const codeTheme = resolvedTheme === "dark" ? "dracula" : "light-plus";

        document.documentElement.dataset.codeTheme = codeTheme;
        document.documentElement.dataset.theme = resolvedTheme;
        document.documentElement.style.colorScheme = resolvedTheme;

        changeGiscusTheme(resolvedTheme);

        document.dispatchEvent(
          new CustomEvent("theme-changed", {
            detail: {
              defaultTheme,
              resolvedTheme,
              systemTheme,
              theme,
            },
          }),
        );
      }

      /** @type {ThemeManager} */
      const api = {
        getSystemTheme() {
          return systemTheme;
        },

        getTheme() {
          const storedTheme = store.getItem(storageKey);
          if (storedTheme === "light" || storedTheme === "dark" || storedTheme === "auto") {
            return storedTheme;
          }

          return defaultTheme;
        },

        resetTheme() {
          store.removeItem(storageKey);
        },

        setTheme(theme = defaultTheme) {
          store.setItem(storageKey, theme);
          applyTheme(theme);
        },
      };

      mediaMatcher.addEventListener("change", (event) => {
        systemTheme = event.matches ? "dark" : "light";
        api.setTheme(api.getTheme());
      });

      return api;
    }

    /** @type {ThemeManager} */
    const theme = window.kdev.theme ?? createThemeManager();
    window.kdev.theme = theme;

    theme.setTheme(theme.getTheme());

    /**
     * @returns {void}
     */
    function initThemeManager() {
      if (!customElements.get("theme-selector")) {
        customElements.define(
          "theme-selector",
          class extends HTMLElement {
            connectedCallback() {
              /** @type {ThemeMode[]} */
              this.themes = ["light", "dark"];

              const button = document.createElement("button");
              button.setAttribute("type", "button");
              button.setAttribute("aria-label", "Toggle theme");
              button.addEventListener("click", () => {
                this.nextTheme();
              });

              this.btn = button;
              this.replaceChildren(button);
              this.updateIcon();

              document.addEventListener("theme-changed", this.handleThemeChanged);
            }

            disconnectedCallback() {
              document.removeEventListener("theme-changed", this.handleThemeChanged);
            }

            handleThemeChanged = () => {
              this.updateIcon();
            };

            nextTheme() {
              try {
                const currentTheme = theme.getTheme();
                const currentIndex = this.themes.indexOf(
                  currentTheme === "auto" ? theme.getSystemTheme() : currentTheme,
                );
                const safeIndex = currentIndex >= 0 ? currentIndex : 0;
                const nextTheme = this.themes[(safeIndex + 1) % this.themes.length];
                theme.setTheme(nextTheme);
              } catch (error) {
                console.error("theme-selector nextTheme failed:", error);
              }
            }

            updateIcon(currentTheme = theme.getTheme()) {
              if (!(this.btn instanceof HTMLButtonElement)) {
                return;
              }

              const visibleTheme = currentTheme === "auto" ? theme.getSystemTheme() : currentTheme;
              const icons = {
                dark: "🌙",
                light: "☀️",
              };

              this.btn.textContent = icons[visibleTheme] ?? icons.dark;
            }
          },
        );
      }

      document.addEventListener("astro:after-swap", () => {
        theme.setTheme(theme.getTheme());
        initMobileMenu();
      });
    }

    window.addEventListener("resize", toggleNavVisibility);
    document.addEventListener("astro:after-swap", initMobileMenu);

    initMobileMenu();
    initStickyBrandObserver();
    initThemeManager();
  })();
</script>
