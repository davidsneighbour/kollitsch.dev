---
import { Icon } from 'astro-icon/components';

export interface Props {}

const isDev = import.meta.env.DEV;

// Keyboard shortcut to restore the hidden dev bar — change this to reconfigure.
// Uses tinykeys syntax: https://github.com/jamiebuilds/tinykeys
const DEVBAR_SHOW_KEY = 'Shift+A';
---

{isDev && (
    <div
      id="dev-bar"
      class="font-jetbrainsmono fixed right-0 bottom-0 left-0 z-[9999] flex items-center gap-3 border-y border-gray-200 bg-gray-100 px-3 py-2 text-sm text-gray-700 transition-opacity duration-200 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-300"
      data-position="bottom"
      data-opacity="full"
      data-show-key={DEVBAR_SHOW_KEY}
    >
      <div class="flex shrink-0 items-center gap-1.5 font-bold">
        <Icon name="lucide:monitor" class="size-4" />
        <span class="sm:hidden">XS</span>
        <span class="hidden sm:inline md:hidden">SM</span>
        <span class="hidden md:inline lg:hidden">MD</span>
        <span class="hidden lg:inline xl:hidden">LG</span>
        <span class="hidden xl:inline 2xl:hidden">XL</span>
        <span class="hidden 2xl:inline">2XL</span>
      </div>

      <div class="max-h-[30vh] min-w-0 flex-1 overflow-auto">
        <button
          id="load-heading-audit"
          class="rounded-md bg-gray-700 px-2 py-0.5 text-xs text-gray-50 transition-colors duration-300 hover:bg-gray-600 dark:bg-gray-600 dark:text-gray-100 dark:hover:bg-gray-500"
        >
          Audit Headings
        </button>
        <div
          id="heading-audit-results"
          class="mt-1 space-y-0.5 text-xs"
        />
      </div>

      <div class="flex shrink-0 items-center gap-1">
        <button
          id="toggle-opacity"
          type="button"
          title="Dim bar to 20% opacity"
          aria-pressed="false"
          class="rounded-md p-1 transition-colors duration-300 hover:bg-gray-200 dark:hover:bg-gray-700"
        >
          <Icon id="opacity-icon-dim" name="lucide:sun-dim" class="size-4" aria-hidden="true" />
          <Icon id="opacity-icon-full" name="lucide:sun" class="hidden size-4" aria-hidden="true" />
          <span class="sr-only">Toggle bar opacity</span>
        </button>

        <button
          id="toggle-position"
          type="button"
          title="Move bar to top"
          class="rounded-md p-1 transition-colors duration-300 hover:bg-gray-200 dark:hover:bg-gray-700"
        >
          <Icon id="position-icon-to-top" name="lucide:panel-top" class="size-4" aria-hidden="true" />
          <Icon id="position-icon-to-bottom" name="lucide:panel-bottom" class="hidden size-4" aria-hidden="true" />
          <span class="sr-only">Toggle bar position</span>
        </button>

        <button
          id="hide-devbar"
          type="button"
          title={`Hide until reload (${DEVBAR_SHOW_KEY} to restore)`}
          class="rounded-md p-1 transition-colors duration-300 hover:bg-gray-200 dark:hover:bg-gray-700"
        >
          <Icon name="lucide:eye-off" class="size-4" aria-hidden="true" />
          <span class="sr-only">Hide until reload</span>
        </button>

        <button
          id="hide-devbar-permanently"
          type="button"
          title="Dismiss (saved to localStorage)"
          class="rounded-md p-1 transition-colors duration-300 hover:bg-gray-200 dark:hover:bg-gray-700"
        >
          <Icon name="lucide:circle-x" class="size-4" aria-hidden="true" />
          <span class="sr-only">Dismiss permanently</span>
        </button>
      </div>
    </div>
  )}

<script>
  import { tinykeys } from 'tinykeys';

  let unsubscribeKeys: (() => void) | null = null;

  function applyPosition(bar: HTMLElement, position: 'top' | 'bottom') {
    const toTopIcon = bar.querySelector<HTMLElement>('#position-icon-to-top');
    const toBottomIcon = bar.querySelector<HTMLElement>(
      '#position-icon-to-bottom',
    );
    const btn = bar.querySelector<HTMLButtonElement>('#toggle-position');

    if (position === 'top') {
      bar.classList.remove('bottom-0');
      bar.classList.add('top-0');
      toTopIcon?.classList.add('hidden');
      toBottomIcon?.classList.remove('hidden');
      if (btn) btn.title = 'Move bar to bottom';
    } else {
      bar.classList.remove('top-0');
      bar.classList.add('bottom-0');
      toTopIcon?.classList.remove('hidden');
      toBottomIcon?.classList.add('hidden');
      if (btn) btn.title = 'Move bar to top';
    }
    bar.dataset['position'] = position;
  }

  function applyOpacity(bar: HTMLElement, opacity: 'full' | 'dim') {
    const dimIcon = bar.querySelector<HTMLElement>('#opacity-icon-dim');
    const fullIcon = bar.querySelector<HTMLElement>('#opacity-icon-full');
    const btn = bar.querySelector<HTMLButtonElement>('#toggle-opacity');

    if (opacity === 'dim') {
      bar.classList.add('opacity-20', 'hover:opacity-100');
      dimIcon?.classList.add('hidden');
      fullIcon?.classList.remove('hidden');
      if (btn) {
        btn.title = 'Restore full opacity';
        btn.setAttribute('aria-pressed', 'true');
      }
    } else {
      bar.classList.remove('opacity-20', 'hover:opacity-100');
      dimIcon?.classList.remove('hidden');
      fullIcon?.classList.add('hidden');
      if (btn) {
        btn.title = 'Dim bar to 20% opacity';
        btn.setAttribute('aria-pressed', 'false');
      }
    }
    bar.dataset['opacity'] = opacity;
  }

  document.addEventListener('astro:before-swap', () => {
    unsubscribeKeys?.();
    unsubscribeKeys = null;
  });

  document.addEventListener('astro:page-load', () => {
    const bar = document.getElementById('dev-bar') as HTMLElement | null;
    if (!bar) return;

    const showKey = bar.dataset['showKey'] ?? 'Shift+A';

    // Support migration from old 'hideDevBar' localStorage key
    const isHidden =
      localStorage.getItem('devBarHidden') === 'true' ||
      localStorage.getItem('hideDevBar') === 'true';
    if (isHidden) {
      bar.classList.add('hidden');
    }

    applyPosition(
      bar,
      (localStorage.getItem('devBarPosition') ?? 'bottom') as 'top' | 'bottom',
    );
    applyOpacity(
      bar,
      (localStorage.getItem('devBarOpacity') ?? 'full') as 'full' | 'dim',
    );

    bar.querySelector('#toggle-opacity')?.addEventListener('click', () => {
      const next = bar.dataset['opacity'] === 'dim' ? 'full' : 'dim';
      localStorage.setItem('devBarOpacity', next);
      applyOpacity(bar, next as 'full' | 'dim');
    });

    bar.querySelector('#toggle-position')?.addEventListener('click', () => {
      const next = bar.dataset['position'] === 'top' ? 'bottom' : 'top';
      localStorage.setItem('devBarPosition', next);
      applyPosition(bar, next as 'top' | 'bottom');
    });

    bar.querySelector('#hide-devbar')?.addEventListener('click', () => {
      bar.classList.add('hidden');
    });

    bar
      .querySelector('#hide-devbar-permanently')
      ?.addEventListener('click', () => {
        localStorage.setItem('devBarHidden', 'true');
        localStorage.removeItem('hideDevBar');
        bar.classList.add('hidden');
      });

    const loadBtn = bar.querySelector('#load-heading-audit');
    const resultsContainer = bar.querySelector<HTMLElement>(
      '#heading-audit-results',
    );

    loadBtn?.addEventListener('click', () => {
      if (!resultsContainer) return;
      resultsContainer.innerHTML = '';

      const headings: Array<{
        level: number;
        node: Element;
        text: string;
        visible: boolean;
      }> = [];
      const walker = document.createTreeWalker(
        document.body,
        NodeFilter.SHOW_ELEMENT,
        {
          acceptNode(node) {
            const el = node as Element;
            const tag = el.tagName?.toLowerCase();
            const isSemantic = /^h[1-6]$/.test(tag);
            const isAria =
              el.getAttribute('role') === 'heading' &&
              el.hasAttribute('aria-level');
            return isSemantic || isAria
              ? NodeFilter.FILTER_ACCEPT
              : NodeFilter.FILTER_SKIP;
          },
        },
      );

      while (walker.nextNode()) {
        const el = walker.currentNode as Element;
        const tag = el.tagName?.toLowerCase();
        const isAria = el.getAttribute('role') === 'heading';
        const level = isAria
          ? parseInt(el.getAttribute('aria-level') ?? '1', 10)
          : parseInt(tag.slice(1), 10);
        const text = el.textContent?.trim() || '(empty)';
        const computed = window.getComputedStyle(el);
        const visible =
          computed.display !== 'none' &&
          computed.visibility !== 'hidden' &&
          el.getAttribute('aria-hidden') !== 'true' &&
          !el.classList.contains('sr-only');

        headings.push({ level, node: el, text, visible });
      }

      for (const h of headings) {
        const item = document.createElement('div');
        item.innerHTML = `<strong>H${h.level}</strong>: ${h.text} <span class="text-xs">[${h.visible ? 'visible' : 'hidden'}]</span>`;
        item.classList.add('cursor-pointer', 'hover:underline');
        item.addEventListener('click', () => {
          h.node.scrollIntoView({ behavior: 'smooth', block: 'center' });
        });
        resultsContainer.appendChild(item);
      }
    });

    unsubscribeKeys = tinykeys(window, {
      [showKey]: (event) => {
        const b = document.getElementById('dev-bar') as HTMLElement | null;
        if (b?.classList.contains('hidden')) {
          b.classList.remove('hidden');
          localStorage.removeItem('devBarHidden');
          event.preventDefault();
        }
      },
    });
  });
</script>
