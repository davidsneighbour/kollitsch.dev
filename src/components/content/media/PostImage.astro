---
import { Picture } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import Youtube from '@components/content/media/Youtube.astro';
import { resolveCover } from '@utils/cover';
import { getTailwindSizes } from '@utils/tailwind.ts';
import type { ImageMetadata } from 'astro';

export interface Props {
  post: CollectionEntry<'blog' | 'tags'>;
  link?: string;
  classes?: string;
  // mapped to 30/60/82/95 or use number directly
  quality?: 'low' | 'medium' | 'high' | 'max' | number;
  widths?: number[];
  formats?: Array<'avif' | 'webp' | 'png' | 'jpeg'>;
  sizes?: string;
  layout?: 'fixed' | 'constrained' | 'full-width';
}

const {
  post,
  link,
  classes = 'w-full max-w-full h-auto',
  quality = 'high',
  widths = [320, 640, 768, 1024],
  formats = ['avif', 'webp', 'jpeg'],
  sizes = getTailwindSizes({ base: 3, maxContentWidth: 1280, md: 2, sm: 1 }),
  layout = 'constrained',
}: Props = Astro.props;

type Quality = number | 'low' | 'medium' | 'high' | 'max';

function mapQuality(q: Quality): number {
  if (typeof q === 'number') {
    return Math.max(1, Math.min(100, q));
  }
  switch (q) {
    case 'low':
      return 30;
    case 'medium':
      return 60;
    case 'high':
      return 82;
    case 'max':
      return 95;
    default: {
      const exhaustiveCheck: never = q;
      throw new Error(`Unhandled quality value: ${String(exhaustiveCheck)}`);
    }
  }
}

const fallbackAlt =
  post.collection === 'tags'
    ? (post.data.linktitle ??
      post.data.title ??
      post.data.description ??
      post.id)
    : (post.data.title ?? post.id);

const cover = resolveCover(
  post.data.cover,
  {
    collection: post.collection,
    id: post.id,
  },
  {
    debug: import.meta.env.DEV,
    fallbackAlt,
    ...(post.collection === 'tags'
      ? { defaultKey: 'defaults/articleimage.jpg', warnOnFallback: false }
      : {}),
  },
);

let imageMeta: ImageMetadata | null =
  cover.type === 'image' && cover.meta ? cover.meta : null;

const sortedWidths = [...new Set(widths)].sort((a, b) => a - b);
const configuredMaxWidth = sortedWidths.at(-1) ?? 0;
const resolvedMaxWidth = imageMeta
  ? Math.min(configuredMaxWidth, imageMeta.width)
  : configuredMaxWidth;
const responsiveWidths =
  resolvedMaxWidth > 0
    ? sortedWidths.filter((width) => width <= resolvedMaxWidth)
    : sortedWidths;
const cappedImageMeta =
  imageMeta && resolvedMaxWidth > 0 && imageMeta.width > resolvedMaxWidth
    ? {
        ...imageMeta,
        height: Math.round(
          imageMeta.height * (resolvedMaxWidth / imageMeta.width),
        ),
        width: resolvedMaxWidth,
      }
    : imageMeta;

// Derived state — only available for blog posts
const isDraft = post.collection === 'blog' && post.data.draft === true;
const postDate = post.collection === 'blog' ? post.data.date : null;

// Extract rounded-* classes from the image classes so the figure can
// carry the same rounding, enabling overflow-hidden to clip at the
// correct corner radius.
const roundedClasses = classes
  .split(/\s+/)
  .filter((c) => c.startsWith('rounded'))
  .join(' ');
---

{cover.type === "video" && cover.video ? (
    // ─── VIDEO ────────────────────────────────────────────────────────────────
    // Caption stays below the video; overlay does not apply to media players.
    // Draft badge still shows so editors can spot unpublished content.
    <figure class="group relative">
      {isDraft && (
        <span class="draft-badge absolute left-2 top-2 z-30 rounded bg-orange-500 px-2 py-0.5 text-xs font-bold uppercase tracking-wider text-white">
          DRAFT
        </span>
      )}
      <div class={`aspect-2/1 overflow-hidden ${classes}`}>
        <Youtube
          label={cover.video.title}
          video={cover.video.youtube}
          classes="z-20 mb-4 h-auto w-full max-w-full"
          params={cover.video.params ?? {}}
        />
      </div>
      <figcaption class="video-caption italic @sm:px-2 @md:px-3 @lg:px-4">
        {cover.video.title}
      </figcaption>
    </figure>
  ) : cover.type === "image" ? (
    // ─── IMAGE ────────────────────────────────────────────────────────────────
    <figure
      class:list={[
        "group/postimg relative @container overflow-hidden",
        roundedClasses,
      ]}
      data-postimage
    >
      {/* Background link — z-10, covers the whole figure, sits below caption */}
      {link && (
        <a
          href={link}
          class="absolute inset-0 z-10 focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-orange-500"
          aria-label={cover.alt}
        />
      )}

      {/* Image — not wrapped in <a>; the background link handles navigation */}
      {cappedImageMeta ? (
        <Picture
          src={cappedImageMeta}
          alt={cover.alt}
          formats={formats}
          widths={responsiveWidths}
          sizes={sizes}
          layout={layout}
          class={classes}
          quality={mapQuality(quality)}
          priority
        />
      ) : (
        <img
          src={cover.src}
          alt={cover.alt}
          class={classes}
          loading="eager"
          decoding="async"
        />
      )}

      {/* DRAFT badge — always visible on draft posts, top-left corner */}
      {isDraft && (
        <span class="draft-badge absolute left-2 top-2 z-30 rounded bg-orange-500 px-2 py-0.5 text-xs font-bold uppercase tracking-wider text-white">
          DRAFT
        </span>
      )}

      {/* Caption overlay — bottom of image, visible on hover (desktop)
          or when .caption-visible is toggled (mobile). Only rendered when
          the post has a cover.title caption. */}
      {cover.title && (
        <figcaption class="caption-overlay absolute inset-x-0 bottom-0 z-20 flex items-end gap-3 bg-linear-to-t from-black/90 via-black/60 to-black/10 px-4 py-3 text-white opacity-0 transition-opacity duration-300 group-hover/postimg:opacity-100 group-[.caption-visible]/postimg:opacity-100">
          {/* Caption text — links get z-30 so they intercept clicks above
              the background <a> link at z-10 */}
          <span
            class="caption-text min-w-0 flex-1 text-sm leading-snug [&_a]:relative [&_a]:z-30 [&_a]:underline [&_a]:decoration-white/60 [&_a]:underline-offset-2 hover:[&_a]:decoration-white"
            set:html={cover.title}
          />
          {/* Publishing date — visible only on images wider than 22rem
              via CSS container query on the figure */}
          {postDate && (
            <time
              class="caption-date hidden flex-none whitespace-nowrap text-xs opacity-70 @[22rem]:block"
              datetime={postDate.toISOString()}
            >
              {postDate.toLocaleDateString("en", {
                day: "numeric",
                month: "short",
                year: "numeric",
              })}
            </time>
          )}
        </figcaption>
      )}

      {/* Mobile info button — shown only on touch/no-hover devices.
          Tapping it toggles .caption-visible on the figure, making the
          caption overlay visible without hover. Hidden on pointer devices. */}
      {cover.title && (
        <button
          data-caption-toggle
          type="button"
          class="caption-toggle absolute bottom-2 right-2 z-30 hidden size-7 items-center justify-center rounded-full bg-black/50 text-white backdrop-blur-sm [@media(hover:none)]:flex"
          aria-label="Show image caption"
          aria-expanded="false"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 20 20"
            fill="currentColor"
            class="size-4"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M18 10a8 8 0 1 1-16 0 8 8 0 0 1 16 0Zm-7-4a1 1 0 1 1-2 0 1 1 0 0 1 2 0ZM9 9a.75.75 0 0 0 0 1.5h.253a.25.25 0 0 1 .244.304l-.459 2.066A1.75 1.75 0 0 0 10.747 15H11a.75.75 0 0 0 0-1.5h-.253a.25.25 0 0 1-.244-.304l.459-2.066A1.75 1.75 0 0 0 9.253 9H9Z"
              clip-rule="evenodd"
            />
          </svg>
        </button>
      )}
    </figure>
  ) : null}

<style>
  @reference "@styles/theme.css";

  /* Video figcaption stays below the video, no overlay treatment */
  .video-caption {
    @apply mt-2 text-sm text-gray-600 dark:text-gray-400;
    @apply lg:text-base xl:text-lg;
  }

  /* caption-visible toggle is handled via Tailwind's
       group-[.caption-visible]/postimg:opacity-100 on the figcaption */
</style>

<script>
  function initPostImageToggles(): void {
    for (const fig of document.querySelectorAll<HTMLElement>(
      '[data-postimage]:not([data-caption-init])',
    )) {
      fig.setAttribute('data-caption-init', '');
      const btn = fig.querySelector<HTMLButtonElement>('[data-caption-toggle]');
      if (!btn) continue;

      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const open = fig.classList.toggle('caption-visible');
        btn.setAttribute('aria-expanded', String(open));
      });
    }
  }

  // Run on initial page load and after every view-transition navigation
  document.addEventListener('astro:page-load', initPostImageToggles);
</script>
