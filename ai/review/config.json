{
  "version": 1,
  "todoFile": "ToDo.md",
  "instructionsFile": "ai/review/instructions.md",
  "ignoreFile": "ai/review/ignore.md",
  "doneFile": "ai/review/done.md",
  "templateFile": "ai/review/template.md",
  "bundleOutputFile": "ai/review/review-bundle.md",
  "instructionPaths": [
    "AGENTS.md",
    "CLAUDE.md",
    ".github/copilot-instructions.md",
    ".github/instructions",
    ".vscode/instructions",
    "ai"
  ],
  "topics": [
    "content",
    "layout",
    "system",
    "ci",
    "testing",
    "types",
    "performance",
    "accessibility",
    "documentation",
    "deps"
  ],
  "validation": {
    "always": [
      "npm run lint",
      "npm run test"
    ],
    "whenChanged": {
      "**/*.md": [
        "npm run lint:markdown"
      ],
      "**/*.astro": [
        "npm run astro check"
      ],
      "**/*.{ts,tsx,js,mjs,cjs}": [
        "npm run lint",
        "npm run test"
      ],
      "package.json": [
        "npm install --package-lock-only",
        "npm run lint"
      ]
    }
  },
  "ranking": {
    "prioritise": [
      "broken tests",
      "instruction violations",
      "type safety",
      "ci gaps",
      "maintainability",
      "documentation gaps",
      "cosmetic issues"
    ]
  },
  "scan": {
    "maxFileBytes": 120000,
    "maxFilesInBundle": 200,
    "commonInterestingFiles": [
      "package.json",
      "tsconfig.json",
      "README.md",
      "AGENTS.md",
      ".github/workflows",
      "src",
      "scripts",
      "ai/review"
    ],
    "exclude": [
      ".git",
      "node_modules",
      "dist",
      "build",
      ".astro",
      ".next",
      ".turbo",
      ".cache",
      "coverage",
      ".DS_Store"
    ]
  },
  "configSchemaFile": "ai/review/config.schema.json"
}
