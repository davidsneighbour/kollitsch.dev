---
export interface Props {
  classes?: string;
}

const { classes = "progress z-40 relative [--height:4px] lg:[--height:6px]" }: Props = Astro.props;
---

<progress class={classes} value="0" max="100" aria-label="Reading progress" data-reading-progress></progress>
<script is:inline>
  (() => {
    window.kdev ??= {};

    if (window.kdev.readingProgressInitialised) {
      return;
    }

    window.kdev.readingProgressInitialised = true;

    const getScroll = () => {
      const d = document.documentElement;
      const b = document.body;
      const top = d.scrollTop || b.scrollTop;
      const height = (d.scrollHeight || b.scrollHeight) - d.clientHeight;
      return height > 0 ? (top / height) * 100 : 0;
    };

    const updateProgress = () => {
      const scroll = getScroll();
      const progressBars = document.querySelectorAll("progress[data-reading-progress]");

      for (const progress of progressBars) {
        if (!(progress instanceof HTMLProgressElement)) {
          continue;
        }

        progress.value = scroll;
        progress.style.setProperty("--scroll", `${scroll}%`);
        progress.toggleAttribute("data-complete", progress.value >= 99.9); //
      }
    };

    document.addEventListener("scroll", updateProgress, { passive: true });
    window.addEventListener("load", updateProgress);
    document.addEventListener("astro:page-load", updateProgress);

    updateProgress();
  })();
</script>

<style>
  @reference "@styles/theme.css";

  @keyframes progress-bar-stripes {
    0% {
      background-position-x: 0;
    }

    100% {
      background-position-x: var(--progress-height);
    }
  }

  .progress {
    --progress-height: var(--thickness, var(--height, 4px));
    --progress-bar-transition: width 0.6s ease;

    @apply block w-full appearance-none rounded-none bg-black/10;
    @apply shadow-[inset_0_1px_2px_rgba(0,0,0,0.075)];

    height: var(--progress-height);
  }

  .progress::-webkit-progress-bar {
    @apply rounded-full bg-black/10;
  }

  .progress::-webkit-progress-value {
    @apply rounded-full bg-brand-main-accent;

    background-image: linear-gradient(
      -45deg,
      rgba(255, 255, 255, 0.15) 25%,
      transparent 25%,
      transparent 50%,
      rgba(255, 255, 255, 0.15) 50%,
      rgba(255, 255, 255, 0.15) 75%,
      transparent 75%,
      transparent
    );
    background-size: var(--progress-height) var(--progress-height);
    animation: progress-bar-stripes 1s linear infinite;
    transition: var(--progress-bar-transition);
  }

  .progress::-moz-progress-bar {
    @apply rounded-full bg-brand-main-accent;

    background-image: linear-gradient(
      -45deg,
      rgba(255, 255, 255, 0.15) 25%,
      transparent 25%,
      transparent 50%,
      rgba(255, 255, 255, 0.15) 50%,
      rgba(255, 255, 255, 0.15) 75%,
      transparent 75%,
      transparent
    );
    background-size: var(--progress-height) var(--progress-height);
    animation: progress-bar-stripes 1s linear infinite;
    transition: var(--progress-bar-transition);
  }

  @media (prefers-reduced-motion: reduce) {
    .progress::-webkit-progress-value,
    .progress::-moz-progress-bar {
      @apply animate-none transition-none;
    }
  }

  .progress:not([data-complete])::-webkit-progress-value,
  .progress:not([data-complete])::-moz-progress-bar {
    @apply rounded-l-none rounded-r-full;

    transition:
      var(--progress-bar-transition),
      border-radius 0.2s ease;
  }

  .progress[data-complete]::-webkit-progress-value,
  .progress[data-complete]::-moz-progress-bar {
    @apply rounded-none;

    transition:
      var(--progress-bar-transition),
      border-radius 0.2s ease;
  }
</style>
