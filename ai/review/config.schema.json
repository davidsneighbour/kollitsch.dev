{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/ai/review/config.schema.json",
  "title": "AI review configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "todoFile",
    "instructionsFile",
    "ignoreFile",
    "doneFile",
    "templateFile",
    "bundleOutputFile",
    "configSchemaFile",
    "instructionPaths",
    "topics",
    "validation",
    "ranking",
    "scan"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "todoFile": {
      "type": "string",
      "minLength": 1
    },
    "instructionsFile": {
      "type": "string",
      "minLength": 1
    },
    "ignoreFile": {
      "type": "string",
      "minLength": 1
    },
    "doneFile": {
      "type": "string",
      "minLength": 1
    },
    "templateFile": {
      "type": "string",
      "minLength": 1
    },
    "bundleOutputFile": {
      "type": "string",
      "minLength": 1
    },
    "configSchemaFile": {
      "type": "string",
      "minLength": 1
    },
    "instructionPaths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "topics": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "always",
        "whenChanged"
      ],
      "properties": {
        "always": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "whenChanged": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "ranking": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prioritise"
      ],
      "properties": {
        "prioritise": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "scan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "maxFileBytes",
        "maxFilesInBundle",
        "commonInterestingFiles",
        "exclude"
      ],
      "properties": {
        "maxFileBytes": {
          "type": "integer",
          "minimum": 1
        },
        "maxFilesInBundle": {
          "type": "integer",
          "minimum": 1
        },
        "commonInterestingFiles": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "exclude": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}