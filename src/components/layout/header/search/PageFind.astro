---
export interface Props {}
---

<pagefind-searchbox style="width: 98%;"></pagefind-searchbox>
<style is:global>
  @reference "@styles/theme.css";
  #pagefind-container {
    /* Colors */
    --pf-text: var(--color-gray-900);
    --pf-text-secondary: var(--color-gray-500);
    --pf-text-muted: var(--color-gray-500);
    --pf-background: var(--color-white);
    --pf-border: var(--color-gray-200);
    --pf-border-focus: var(--color-gray-400);
    --pf-skeleton: var(--color-gray-200);
    --pf-skeleton-shine: var(--color-gray-100);
    --pf-hover: var(--color-gray-100);
    --pf-mark: var(--color-gray-900);
    --pf-scroll-shadow: color-mix(in oklab, var(--color-black) 8%, transparent);

    /* Shadows */
    --pf-shadow-sm: var(--shadow-sm);
    --pf-shadow-md: var(--shadow-md);
    --pf-shadow-lg: var(--shadow-lg);

    /* Error states */
    --pf-error-bg: var(--color-red-50);
    --pf-error-border: var(--color-red-200);
    --pf-error-text: var(--color-red-600);
    --pf-error-text-secondary: var(--color-red-700);

    /* Focus ring */
    --pf-outline-focus: var(--color-brand-main-accent);
    --pf-outline-width: calc(var(--spacing) * 0.5);
    --pf-outline-offset: calc(var(--spacing) * 0.5);

    /* Typography */
    --pf-font: var(--font-sans);

    /* Sizing */
    --pf-input-height: calc(var(--spacing) * 9);
    --pf-input-font-size: var(--text-base); /* Keep at 16px+ to prevent iOS auto-zoom on focus */
    --pf-summary-font-size: var(--text-2xl);
    --pf-result-title-font-size: var(--text-2xl);
    --pf-result-excerpt-font-size: var(--text-2xl);

    /* Results layout */
    --pf-results-display: flex;
    --pf-results-flex-direction: column;
    --pf-results-flex-wrap: nowrap;
    --pf-results-columns: none; /* grid-template-columns value, used when display is grid */
    --pf-results-gap: calc(var(--spacing) * 2);

    --pf-border-radius: var(--radius-sm);
    --pf-image-width: calc(var(--spacing) * 16);
    --pf-image-height: calc(var(--spacing) * 12);

    /* Icons (SVG data URIs) */
    /* --pf-icon-search: url("data:image/svg+xml,...");
    --pf-icon-arrow: url("data:image/svg+xml,..."); */

    /* Modal */
    --pf-modal-backdrop: color-mix(in oklab, var(--color-black) 50%, transparent);
    --pf-modal-max-width: calc(var(--spacing) * 140);
    --pf-modal-max-height: min(80dvh, calc(var(--spacing) * 200));
    --pf-modal-top: 10dvh;

    /* Searchbox dimensions */
    --pf-searchbox-dropdown-max-height: calc(var(--spacing) * 80);

    /* Dropdown settings */
    --pf-dropdown-max-height: calc(var(--spacing) * 70);
    --pf-dropdown-z-index: var(--z-50);
  }
  [data-theme="dark"] #pagefind-container {
    --pf-text: var(--color-gray-200);
    --pf-text-secondary: var(--color-gray-400);
    --pf-text-muted: var(--color-gray-400);
    --pf-background: var(--color-gray-900);
    --pf-border: var(--color-gray-700);
    --pf-border-focus: var(--color-gray-600);
    --pf-skeleton: var(--color-gray-800);
    --pf-skeleton-shine: var(--color-gray-700);
    --pf-hover: var(--color-gray-800);
    --pf-mark: var(--color-gray-200);
    --pf-scroll-shadow: color-mix(in oklab, var(--color-white) 10%, transparent);
    --pf-outline-focus: var(--color-brand-main-accent);

    --pf-shadow-sm: var(--shadow-sm);
    --pf-shadow-md: var(--shadow-md);
    --pf-shadow-lg: var(--shadow-lg);

    --pf-error-bg: var(--color-red-950);
    --pf-error-border: var(--color-red-900);
    --pf-error-text: var(--color-red-400);
    --pf-error-text-secondary: var(--color-red-500);
  }
</style>
<script is:inline src="/pagefind/pagefind-component-ui.js" type="module"></script>
<!-- `npx astro build` must have run once to generate the pagefind styles in the dist directory -->
<link href="/pagefind/pagefind-component-ui.css" rel="stylesheet" />
