---
import LetterGlitch from "@components/gimmicks/LetterGlitch.astro";
---

<section class="relative z-10 border-t border-border bg-background-secondary py-24">
  <div class="mx-auto max-w-2xl px-6 text-center lg:hidden">
    <h2 class="mb-4 text-4xl font-bold">Have a project in mind?</h2>
    <p class="mb-8 text-lg">The lightweight fallback for mobile and coarse-pointer devices.</p>
  </div>

  <LetterGlitch>
    <div>
      <h2 class="mb-4 text-4xl font-bold">Have a project in mind?</h2>
      <p class="mb-8 text-lg">The animated canvas version for desktop and fine-pointer devices.</p>
    </div>
  </LetterGlitch>
</section>
