{
  "scripts": {
    // add enabled extensions to the recommendations file and show overview
    "build:vscode:recommendations": "node --disable-warning=ExperimentalWarning src/scripts/vscode/vscode-extensions.ts --fix",
    "ci:check:vscode": "npm run vscode:check",
    "postinstall:vscode": "npm run vscode:sync",
    "vscode:check": "node src/scripts/vscode/merge-vscode-config.ts --check",
    "vscode:sync": "node src/scripts/vscode/merge-vscode-config.ts --apply"
  }
}
