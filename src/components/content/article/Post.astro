---
// @todo refactor and comment
// create a single blog post with full content

import type { CollectionEntry } from "astro:content";

import BreadCrumbs from "@components/content/navigation/BreadCrumbs.astro";
import Giscus from "@components/features/comments/Giscus.astro";
import Heading from "@components/content/typography/Heading.astro";
import PaginationSingle from "@/components/content/pagenav/PaginationSingle.astro";
import PostImage from "@components/content/media/PostImage.astro";
import Meta from "@components/content/metadata/PostMeta.astro";
import Prose from "@components/content/typography/Prose.astro";
import ShareSeparator from "@components/content/metadata/ShareSeparator.astro";
import SchemaBlogPost from "@components/seo/schema/BlogPosting.astro";
import Komut from "@components/content/typography/Komut.astro";

export interface Props {
  post: CollectionEntry<"blog">;
}

const { post }: Props = Astro.props;
---

<article transition:animate="slide" class="@container mt-8">
  <PostImage post={post} link={`/blog/${post.id}/`} classes="max-w-full aspect-2/1 object-cover rounded-t-4xl" />
  <Heading level={1} class="heading" link={`/blog/${post.id}/`} html={post.data.title} />
  <BreadCrumbs path={post.filePath ?? ""} />
  <Prose post={post} />
  <Komut class="text-gray-600 inline-block align-middle reading-xl" />
  <ShareSeparator title={post.data.title} description={post.data.description} />
  <PaginationSingle post={post} />
  <Giscus post={post} />
  <Meta post={post} />
  <SchemaBlogPost post={post} />
</article>
