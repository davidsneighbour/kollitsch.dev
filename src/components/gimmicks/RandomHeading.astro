---
import headings from "@data/random-headings.json" with { type: "json" };

export interface Props {
  text: string;
  slug: keyof typeof headings;
  class?: string;
}

const { text, slug, class: className } = Astro.props;
const alternatives: string[] = headings[slug] ?? [];
---

<h2 data-random-heading={slug} class={className}>{text}</h2>

<script is:inline define:vars={{ alternatives, slug, text }}>
  document.addEventListener("DOMContentLoaded", () => {
    const pool = [text, ...alternatives];
    const el = document.querySelector(`[data-random-heading="${slug}"]`);
    if (!el) return;
    el.textContent = pool[Math.floor(Math.random() * pool.length)];
  });
</script>
